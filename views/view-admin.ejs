<%- include('partials/header') %>
<div class="page-body">
   <div class="container-fluid">
            <div class="page-title"> 
              <div class="row">
                <div class="col-12 col-sm-6">
                  <h3>View Admin Table</h3>
                </div>
                <div class="col-12 col-sm-6">
                  <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="index.html">                                       <i data-feather="home"> </i></a></li>
                    <li class="breadcrumb-item">View Admin</li>
                    <li class="breadcrumb-item active"> <a href="/dashboard">Dashboard</a></li>
                  </ol>
                </div>
              </div>
            </div>
          </div>

  <div class="container-fluid p-4">
    <div class="row">


      <div class="col-sm-12">
        <div class="card">
          
           
           
        
            <!-- <form class="d-flex align-items-center" method="GET" action="/admin/view-admin">
              <input class="form-control flex-grow-1 me-2" type="text" name="search" value="<%= search || '' %>" placeholder="Search admin" style="min-width: 0;">
              <button class="btn btn-primary" type="submit" style="white-space: nowrap;">Search</button>
            </form> -->
        
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr class="table-info fs-6">
                  <th scope="col">Sr</th>
                  <th scope="col">Photo</th>
                  <th scope="col">First Name</th>
                  <th scope="col">Last Name</th>
                  <th scope="col">Username</th>
                  <th scope="col">Email</th>
                  <th scope="col">Mobile</th>
                  <th scope="col">Gender</th>
                  <th scope="col">Role</th>
                  <th scope="col">City</th>
                  <th scope="col">Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (admins && admins.length > 0) { %>
                <% admins.forEach((adminItem, index) => { %>
                <tr>
                  <th scope="row"><%= index + 1 %></th>
                  <td>
                    <% if (adminItem.photo) { %>
                    <div style="width:60px;height:60px;overflow:hidden;border-radius:50%;cursor:pointer;" onclick="showPhotoModal('<%= adminItem._id %>', '<%= adminItem.firstName %>', '<%= adminItem.lastName %>', '<%= adminItem.photo %>')">
                      <img src="<%= adminItem.photo %>" alt="photo" style="width:100%;height:100%;object-fit:cover;display:block;">
                    </div>
                    <% } else { %>
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:60px;height:60px;cursor:pointer;" onclick="showPhotoModal('<%= adminItem._id %>', '<%= adminItem.firstName %>', '<%= adminItem.lastName %>', '<%= adminItem.photo %>')">
                      <%= ((adminItem.firstName || adminItem.lastName) ? (adminItem.firstName || adminItem.lastName) : 'A').charAt(0).toUpperCase() %>
                    </div>
                    <% } %>
                  </td>
                  
                  <td><%= adminItem.firstName || '-' %></td>
                  <td><%= adminItem.lastName || '-' %></td>
                  <td><%= adminItem.username || '-' %></td>
                  <td><%= adminItem.email %></td>
                  <td><%= adminItem.mobile || '-' %></td>
                  <td><%= adminItem.gender || '-' %></td>
                  <td><%= adminItem.role %></td>
                  <td><%= adminItem.city || '-' %></td>
                  <td class="text-size-18">
                    <a href="/admin/add-admin?id=<%= adminItem._id %>" class="btn btn-sm btn-link p-0 me-2" style="vertical-align: middle;">
                      <i class="icofont icofont-ui-edit text-info"></i>
                    </a>
                    <form action="/admin/admin/<%= adminItem._id %>?_method=DELETE" method="POST" style="display:inline;">
                      <button type="submit" class="btn btn-sm btn-link p-0" style="vertical-align: middle;">
                        <i class="icofont icofont-delete-alt text-danger"></i>
                      </button>
                    </form>
                  </td>
                </tr>
                <% }) %>
                <% } else { %>
                <tr>
                  <td colspan="11" class="text-center">No admins found</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
          <% if (totalPages > 1) { %>
          <div class="card-footer">
            <nav>
              <ul class="pagination justify-content-center mb-0">
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="/admin/view-admin?page=<%= i %>&search=<%= search || '' %>"><%= i %></a>
                  </li>
                <% } %>
              </ul>
            </nav>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Photo Modal -->
<div class="modal fade" id="photoModal" tabindex="-1" role="dialog" aria-labelledby="photoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="photoModalLabel">Admin Photo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <div class="mb-3">
          <img id="modalPhotoPreview" src="/assets/images/user/user-dp.png" alt="photo" style="width:200px;height:200px;object-fit:cover;border-radius:50%;background:#f5f5f5;display:inline-block;">
        </div>
        <p id="modalAdminName" class="fw-bold"></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
function showPhotoModal(adminId, firstName, lastName, photoUrl) {
  const photoModal = new bootstrap.Modal(document.getElementById('photoModal'), {});
  const adminName = (firstName + ' ' + lastName).trim() || 'Admin';
  document.getElementById('modalPhotoPreview').src = photoUrl || '/assets/images/user/user-dp.png';
  document.getElementById('modalAdminName').textContent = adminName;
  photoModal.show();
}
</script>

<%- include('partials/footer') %>
